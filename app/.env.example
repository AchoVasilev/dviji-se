# ===========================================
# Server
# ===========================================
PORT=8080
ENV=production
BASE_URL=https://your-domain.com

# ===========================================
# Database (Railway provides these)
# ===========================================
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=railway
DB_SSL_MODE=require
DB_MAX_CONNS=10

# ===========================================
# Security (generate with: openssl rand -hex 32)
# ===========================================
JWT_ACCESS_KEY=
JWT_REFRESH_KEY=
XSRF=

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=https://your-domain.com

# ===========================================
# Registration (disabled by default)
# ===========================================
ALLOW_REGISTRATION=false

# ===========================================
# Email (optional - for password reset)
# ===========================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# ===========================================
# Cloudinary (optional - for image uploads)
# ===========================================
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=dviji-se

# ===========================================
# TinyMCE (WYSIWYG editor for admin)
# ===========================================
TINYMCE_URL=https://cdn.tiny.cloud/1/your-api-key/tinymce/6/tinymce.min.js

# ===========================================
# OAuth (optional - for social login)
# ===========================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ===========================================
# Ads (optional - for monetization)
# ===========================================
# ADS_ENABLED=false
# GOOGLE_ADS_CLIENT_ID=
